<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>Data Quality Alert: {{ suite_name }}</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 0; padding: 20px; background: #f5f5f5; }
    .container { max-width: 600px; margin: 0 auto; background: #fff; border-radius: 8px; padding: 24px; }
    h1 { font-size: 18px; margin-top: 0; }
    .status-pass { color: #2e7d32; }
    .status-fail { color: #c62828; }
    table { width: 100%; border-collapse: collapse; margin: 16px 0; }
    th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #e0e0e0; }
    th { background: #f5f5f5; font-weight: 600; }
    ul { padding-left: 20px; }
    .severity-critical { color: #c62828; font-weight: 700; }
    .severity-high { color: #e65100; font-weight: 600; }
    .severity-medium { color: #f9a825; }
    .severity-low { color: #2e7d32; }
    .footer { margin-top: 24px; font-size: 12px; color: #757575; }
  </style>
</head>
<body>
<div class="container">
  <h1>Data Quality Alert: {{ suite_name }}</h1>

  <table>
    <tr>
      <th>Status</th>
      <td>
        {% if success %}
        <span class="status-pass">PASSED</span>
        {% else %}
        <span class="status-fail">FAILED</span>
        {% endif %}
      </td>
    </tr>
    <tr><th>Batch</th><td>{{ batch_name }}</td></tr>
    <tr><th>Timestamp</th><td>{{ timestamp }}</td></tr>
    <tr><th>Success Rate</th><td>{{ "%.1f"|format(success_rate) }}%</td></tr>
    <tr><th>Checks</th><td>{{ evaluated_checks }} evaluated, {{ failed_checks }} failed</td></tr>
  </table>

  {% if threshold_failures %}
  <h2>Threshold Violations</h2>
  <ul>
    {% for failure in threshold_failures %}
    <li>{{ failure }}</li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if failed_expectations %}
  <h2>Failed Expectations</h2>
  <ul>
    {% for exp in failed_expectations %}
    <li>
      <span class="severity-{{ exp.severity }}">
        [{{ exp.severity | upper }}]
      </span>
      {{ exp.expectation }} on column '{{ exp.column }}'
    </li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if severity_stats %}
  <h2>Severity Breakdown</h2>
  <table>
    <tr><th>Severity</th><th>Passed</th><th>Total</th></tr>
    {% for severity, stats in severity_stats.items() %}
    {% if stats.total > 0 %}
    <tr>
      <td class="severity-{{ severity }}">{{ severity | upper }}</td>
      <td>{{ stats.passed }}</td>
      <td>{{ stats.total }}</td>
    </tr>
    {% endif %}
    {% endfor %}
  </table>
  {% endif %}

  <div class="footer">
    Generated by DQ Framework &mdash; {{ timestamp }}
  </div>
</div>
</body>
</html>
